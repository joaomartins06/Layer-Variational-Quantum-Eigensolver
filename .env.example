# Template for IBM Quantum credentials.
# Copy this file to .env and fill in your values.
# .env is gitignored — .env.example is safe to commit.

# channel="ibm_quantum_platform" (used in the notebooks) requires:
#   IBM_QUANTUM_TOKEN   : API token from https://quantum.ibm.com/ -> Account -> API token
#   IBM_QUANTUM_INSTANCE: hub/group/project — open plan default is ibm-q/open/main

IBM_QUANTUM_TOKEN=your_token_here
IBM_QUANTUM_INSTANCE=
# Leave IBM_QUANTUM_INSTANCE empty — ibm_quantum_platform discovers your instance
# automatically from the token. Only set this if you have multiple instances and
# want to target a specific one (format is a CRN, not hub/group/project).

# Set to "true" to run on real hardware; "false" uses local fake backend.
USE_REAL_HARDWARE=false
