# Template for IBM Quantum credentials.
# Copy this file to .env and fill in your values.
# .env is gitignored — .env.example is safe to commit.

# ── Primary token ──────────────────────────────────────────────────────────────
# Used by all notebooks (MaxCut, community detection, etc.).
IBM_QUANTUM_TOKEN=your_first_token_here
IBM_QUANTUM_INSTANCE=ibm-q/open/main

# ── Additional tokens (community detection notebook only) ──────────────────────
# The notebook cycles through these in order when the previous token's usage runs out:
#   IBM_QUANTUM_TOKEN  ->  IBM_QUANTUM_TOKEN_2  ->  IBM_QUANTUM_TOKEN_3  ->  fake backend
#
# Rules:
#   - Add as many numbered entries as you have tokens.
#   - The chain stops at the first empty (or missing) slot.
#   - Leave all entries below blank if you only have one token.
IBM_QUANTUM_TOKEN_2=your_second_token_here
IBM_QUANTUM_INSTANCE_2=ibm-q/open/main

IBM_QUANTUM_TOKEN_3=
IBM_QUANTUM_INSTANCE_3=

# To add a fourth token, uncomment:
# IBM_QUANTUM_TOKEN_4=your_fourth_token_here
# IBM_QUANTUM_INSTANCE_4=ibm-q/open/main

# ── Hardware toggle ────────────────────────────────────────────────────────────
# Set to "true" to run on real hardware; "false" uses a local fake backend.
USE_REAL_HARDWARE=false
